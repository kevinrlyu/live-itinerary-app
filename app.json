{
  "expo": {
    "name": "Trotter",
    "slug": "live-itinerary-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#fc7166"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kevin.rl.yu.live-itinerary-app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "iosamap"
        ],
        "LSSupportsOpeningDocumentsInPlace": true,
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Trotter Itinerary",
            "CFBundleTypeRole": "Viewer",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": ["com.kevin.rl.yu.trotter"]
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.kevin.rl.yu.trotter",
            "UTTypeDescription": "Trotter Itinerary",
            "UTTypeConformsTo": ["public.json", "public.data"],
            "UTTypeTagSpecification": {
              "public.filename-extension": ["trotter"],
              "public.mime-type": ["application/x-trotter"]
            }
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kevin.rl.yu.liveitineraryapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withTrotterFileImport"
    ],
    "extra": {
      "eas": {
        "projectId": "3a8b6332-40dd-4d53-af24-7906b613aae8"
      }
    }
  }
}
